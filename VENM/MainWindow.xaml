<Window x:Class="VENM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VENM"
        mc:Ignorable="d"
        Title="Визуальный Редактор Файлов" 
        Height="450" Width="800" 
        MinWidth="640" MinHeight="400"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <!-- 🔹 RowDefinitions: фиксированные строки + одна адаптивная -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Режимы редактирования -->
            <RowDefinition Height="Auto"/>
            <!-- Выбор файлов -->
            <RowDefinition Height="*"/>
            <!-- 🔹 Текстбоксы (адаптивная высота) -->
            <RowDefinition Height="Auto"/>
            <!-- Панель действий -->
        </Grid.RowDefinitions>

        <!-- ───────────────────────────────────────────────────── -->
        <!-- 🔹 Строка 0: Переключатели режимов редактирования-->
        <!-- ───────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,8,10,8">
            <RadioButton x:Name="RadioScEdit" Content="Редактор Сцены" Margin="0,0,15,0" 
                         Checked="RadioScEdit_Checked"/>
            <RadioButton x:Name="RadioObEdit" Content="Редактор Объекта" Margin="0,0,15,0"
                         Checked="RadioObEdit_Checked"/>
            <RadioButton x:Name="RadioFoEditor" Content="Редактор Шрифтов"
                         Checked="RadioFoEdit_Checked"/>
        </StackPanel>

        <!-- ───────────────────────────────────────────────────── -->
        <!-- 🔹 Строка 1: Выбор файлов (фиксированная высота) -->
        <!-- ───────────────────────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="10,0,10,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Сцена:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="ComboScene" Grid.Column="1" Margin="0,0,10,0" 
                      IsReadOnly="True" SelectionChanged="Combo_SelectionChanged"/>

            <TextBlock Grid.Column="2" Text="Объект:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="ComboObject" Grid.Column="3" Margin="0,0,10,0"
                      IsReadOnly="True" SelectionChanged="Combo_SelectionChanged"/>

            <TextBlock Grid.Column="4" Text="Файл:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="ComboFile" Grid.Column="5"
                      IsReadOnly="True" SelectionChanged="Combo_SelectionChanged"/>
        </Grid>

        <!-- ───────────────────────────────────────────────────── -->
        <!-- 🔹 Строка 2: Адаптивная область редактора и превью -->
        <!-- ───────────────────────────────────────────────────── -->
        <Grid Grid.Row="2" Margin="10,0,10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая часть: Редактор -->
            <Grid Grid.Column="0">
                <TextBox x:Name="TextEditor" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Visibility="Visible"/>
                <ScrollViewer x:Name="JsonEditorScroll" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <StackPanel x:Name="JsonEditorPanel" Margin="5"/>
                </ScrollViewer>
            </Grid>

            <!-- Правая часть: Превью -->
            <Grid Grid.Column="2">
                <TextBox x:Name="TextPreview" TextWrapping="Wrap" IsReadOnly="True" Background="#F5F5F5" VerticalScrollBarVisibility="Auto" Visibility="Visible"/>
                <ScrollViewer x:Name="JsonPreviewScroll" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <StackPanel x:Name="JsonPreviewPanel" Margin="5"/>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ───────────────────────────────────────────────────── -->
        <!-- 🔹 Строка 3: Кнопки действий (фиксированная высота) -->
        <!-- ───────────────────────────────────────────────────── -->
        <Grid Grid.Row="3" Margin="10,8,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Левая группа кнопок -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button x:Name="BtnOpenResources" Content="Открыть ресурсы" 
                        Margin="0,0,5,0" Click="BtnOpenResources_Click"/>
                <Button x:Name="BtnCreateDemo" Content="Создать демо-структуру" 
                        Margin="0,0,5,0" Click="BtnCreateDemo_Click"/>
                <Button x:Name="BtnCreate" Content="+ создать сцену" Margin="0,0,5,0"
                        Click="BtnCreate_Click" Height="20" VerticalAlignment="Bottom"/>
                <Button x:Name="BtnDelete" Content="- удалить сцену" 
                    Click="BtnDelete_Click" Height="20"/>
            </StackPanel>

            <!-- Правая группа: Автосохранение + Сохранить -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <CheckBox x:Name="AutoSave" Content="Автосохранение" 
                          Margin="0,0,10,0"
                          Checked="AutoSave_Checked" Unchecked="AutoSave_Unchecked"/>
                <Button x:Name="BtnSave" Content="сохранить" Width="80" Click="BtnSave_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>